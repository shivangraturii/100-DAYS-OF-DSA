#include <stdio.h>
#include <stdlib.h>

// Tree Node
struct Node {
    int data;
    struct Node* left;
    struct Node* right;
};

// Create new node
struct Node* newNode(int val) {
    struct Node* node = (struct Node*)malloc(sizeof(struct Node));
    node->data = val;
    node->left = node->right = NULL;
    return node;
}

// Build Tree (O(n))
struct Node* buildTree(int preorder[], int inorder[], int inStart, int inEnd, int* preIndex, int map[]) {
    if (inStart > inEnd)
        return NULL;

    // Pick current root from preorder
    int rootVal = preorder[*preIndex];
    (*preIndex)++;

    struct Node* root = newNode(rootVal);

    // If leaf node
    if (inStart == inEnd)
        return root;

    // Get index from map (O(1))
    int inIndex = map[rootVal];

    // Build left and right subtree
    root->left = buildTree(preorder, inorder, inStart, inIndex - 1, preIndex, map);
    root->right = buildTree(preorder, inorder, inIndex + 1, inEnd, preIndex, map);

    return root;
}

// Postorder traversal
void postorder(struct Node* root) {
    if (root == NULL)
        return;

    postorder(root->left);
    postorder(root->right);
    printf("%d ", root->data);
}

int main() {
    int n;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    int preorder[n], inorder[n];

    printf("Enter preorder traversal:\n");
    for (int i = 0; i < n; i++)
        scanf("%d", &preorder[i]);

    printf("Enter inorder traversal:\n");
    for (int i = 0; i < n; i++)
        scanf("%d", &inorder[i]);

    // Create map (assuming values are <= 1000)
    int map[1001];
    for (int i = 0; i < n; i++) {
        map[inorder[i]] = i;
    }

    int preIndex = 0;

    struct Node* root = buildTree(preorder, inorder, 0, n - 1, &preIndex, map);

    printf("Postorder traversal:\n");
    postorder(root);

    return 0;
}
