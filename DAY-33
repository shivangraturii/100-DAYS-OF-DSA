#include <stdio.h>
#include <ctype.h>
#include <string.h>

#define MAX 100

char stack[MAX];
int top = -1;

void push(char x) {
    stack[++top] = x;
}

char pop() {
    if (top == -1)
        return -1;
    else
        return stack[top--];
}

int priority(char x) {
    if (x == '(')
        return 0;
    if (x == '+' || x == '-')
        return 1;
    if (x == '*' || x == '/')
        return 2;
    if (x == '^')
        return 3;
    return 0;
}

int main() {
    char exp[MAX], postfix[MAX];
    int i = 0, k = 0;
    char ch;

    printf("Enter Infix Expression: ");
    scanf("%s", exp);

    while (exp[i] != '\0') {
        ch = exp[i];

        if (isalnum(ch))
            postfix[k++] = ch;

        else if (ch == '(')
            push(ch);

        else if (ch == ')') {
            while ((ch = pop()) != '(')
                postfix[k++] = ch;
        }

        else {
            while (top != -1 && priority(stack[top]) >= priority(ch))
                postfix[k++] = pop();
            push(ch);
        }

        i++;
    }

    while (top != -1)
        postfix[k++] = pop();

    postfix[k] = '\0';

    printf("Postfix Expression: %s", postfix);

    return 0;
}
