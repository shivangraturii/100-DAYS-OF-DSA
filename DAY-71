#include <stdio.h>
#include <string.h>

#define EMPTY -1

int main() {
    int m, q;
    
    // Size of hash table
    scanf("%d", &m);
    
    int table[m];
    
    // Initialize table
    for(int i = 0; i < m; i++)
        table[i] = EMPTY;

    // Number of operations
    scanf("%d", &q);

    while(q--) {
        char op[10];
        int key;
        
        scanf("%s %d", op, &key);

        // INSERT operation
        if(strcmp(op, "INSERT") == 0) {
            int i = 0;
            int index;

            while(i < m) {
                index = (key % m + i * i) % m;

                if(table[index] == EMPTY) {
                    table[index] = key;
                    break;
                }
                i++;
            }
        }

        // SEARCH operation
        else if(strcmp(op, "SEARCH") == 0) {
            int i = 0;
            int index;
            int found = 0;

            while(i < m) {
                index = (key % m + i * i) % m;

                if(table[index] == key) {
                    found = 1;
                    break;
                }
                else if(table[index] == EMPTY) {
                    break;
                }
                i++;
            }

            if(found)
                printf("FOUND\n");
            else
                printf("NOT FOUND\n");
        }
    }

    return 0;
}
